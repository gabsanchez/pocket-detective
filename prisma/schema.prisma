// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum FinancialAccountType {
  CASH
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
}

enum CategoryKind {
  EXPENSE
  INCOME
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
}

// ─── Auth.js models ─────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  financialAccounts FinancialAccount[]
  categories        Category[]
  transactions      Transaction[]
  budgets           Budget[]
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Financial models ───────────────────────────────────

model FinancialAccount {
  id                  String               @id @default(uuid()) @db.Uuid
  userId              String               @db.Uuid
  name                String
  type                FinancialAccountType
  currency            String               @db.Char(3)
  openingBalanceCents BigInt               @default(0)
  archived            Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId, archived])
  @@index([userId, type])
}

model Category {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String?      @db.Uuid
  name      String
  kind      CategoryKind
  parentId  String?      @db.Uuid
  archived  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]    @relation("CategoryParent")
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, kind, name])
  @@index([userId, kind])
  @@index([parentId])
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @db.Uuid
  accountId   String          @db.Uuid
  categoryId  String?         @db.Uuid
  type        TransactionType
  amountCents BigInt
  currency    String          @db.Char(3)
  occurredAt  DateTime        @db.Timestamptz(6)
  description String          @default("")
  merchant    String?
  notes       String?
  transferId  String?         @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  FinancialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt(sort: Desc)])
  @@index([accountId, occurredAt(sort: Desc)])
  @@index([categoryId, occurredAt(sort: Desc)])
  @@index([userId, transferId])
}

model Budget {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  categoryId  String   @db.Uuid
  month       DateTime @db.Date
  amountCents BigInt
  currency    String   @db.Char(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month])
  @@index([userId, month])
}
